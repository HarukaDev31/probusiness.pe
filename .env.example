# Copiar a .env y ajustar URLs según tu máquina.
# Laravel intranet (back) — típico con `php artisan serve`:
#   LARAVEL_API_BASE_URL=http://127.0.0.1:8000/api
#
# Si usas otro host/puerto o la carpeta `public` de Laravel en Apache:
#   LARAVEL_API_BASE_URL=http://localhost/tu-proyecto-back/public/api
#
# Opcional: URL completa del JSON de planes (si se define, tiene prioridad sobre LARAVEL_API_BASE_URL)
# API_CURSO_MEMBRESIA_PLANES_URL=http://127.0.0.1:8000/api/public/curso-membresia/planes

LARAVEL_API_BASE_URL=http://127.0.0.1:8000/api

# Opcional: base ubigeo si difiere (sin slash final)
# API_PUBLIC_UBICACION_BASE_URL=http://127.0.0.1:8000/api/public/ubicacion

# API_CURSO_MEMBRESIA_PLANES_URL=
